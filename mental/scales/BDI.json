  "questions": [
    {
      "id": "P1",
      "text": "Les journées sont trop courtes pour tout le travail que j'ai à faire",
      "options": {
        "3": "Tout à fait vrai",
        "2": "Plutôt vrai",
        "1": "Plutôt faux",
        "0": "Tout à fait faux"
      }
    },
    {
      "id": "C2",
      "text": "Je ne peux pas prévoir le travail que je ferai dans un an",
